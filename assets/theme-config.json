{
    "editor": {
        "allowed_blocks": [
            "core/paragraph",
            "core/heading",
            "core/list",
            "core/list-item",
            "core/quote",
            "core/table",
            "core/image",
            "core/buttons",
            "core/button",
            "core/columns",
            "core/column",
            "core/group",
            "core/row",
            "core/stack",
            "core/separator",
            "core/embed",
            "core/shortcode",
            "core/html",
            "core/freeform",
            "core/block",
            "core/missing"
        ],
        "disabled_blocks": [
            "core/pullquote",
            "core/verse",
            "core/preformatted",
            "core/code",
            "core/gallery",
            "core/audio",
            "core/video",
            "core/file",
            "core/cover",
            "core/media-text",
            "core/spacer"
        ]
    },
    "colors": {
        "base": {
            "darkgreen": {
                "color": "#1e4545",
                "name": "Dark Green",
                "block_editor": true,
                "foreground": "var(--color-white)",
                "properties": {
                    "--link--color": "var(--color-white)",
                    "--link--color-hover": "var(--color-white)"
                }
            },
            "lightgreen": {
                "color": "#9db9b9",
                "name": "Light Green",
                "block_editor": true,
                "foreground": "var(--color-black)",
                "properties": {
                    "--link--color": "var(--color-black)",
                    "--link--color-hover": "var(--color-black)"
                }
            },
            "blue": {
                "color": "#1d324e",
                "name": "Blue",
                "block_editor": true,
                "foreground": "var(--color-white)",
                "properties": {
                    "--link--color": "var(--color-white)",
                    "--link--color-hover": "var(--color-white)"
                }
            },
            "peach": {
                "color": "#ebca98",
                "name": "Peach",
                "block_editor": true
            },
            "lightblue": {
                "color": "#87d1d5"
            },
            "red": {
                "color": "#ad474b",
                "foreground": "var(--color-white)",
                "properties": {
                    "--link--color": "var(--color-white)",
                    "--link--color-hover": "var(--color-white)"
                }
            },
            "white": {
                "color": "#fff",
                "foreground": "var(--color-brand-1)"
            },
            "black": {
                "color": "#222",
                "foreground": "var(--color-white)",
                "properties": {
                    "--link--color": "var(--color-white)",
                    "--link--color-hover": "var(--color-white)"
                }
            },
            "grey": {
                "color": "#444",
                "foreground": "var(--color-white)",
                "properties": {
                    "--link--color": "var(--color-white)",
                    "--link--color-hover": "var(--color-white)"
                }
            },
            "brand-1": {
                "namedColor": "darkgreen"
            },
            "brand-2": {
                "namedColor": "lightgreen"
            },
            "brand-3": {
                "namedColor": "peach"
            },
            "foreground": {
                "namedColor": "darkgreen"
            },
            "background": {
                "namedColor": "white"
            },
            "error": {
                "namedColor": "red"
            }
        }
    }
}
