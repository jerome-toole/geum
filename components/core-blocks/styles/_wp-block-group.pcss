/* wp-block-group */
/* */
/* When a group contains blocks, apply the same child spacing as content-flow. */
/* For grid layout groups, switch to CSS grid above md. */

.wp-block-group {
    @apply content-flow;
}

.wp-block-group.is-layout-grid {
    @media (width >= theme('screens.md')) {
        display: grid;
        grid-template-columns: repeat(var(--cols, 2), 1fr);
        gap: var(--flow-space, var(--space-layout));

        > * {
            margin-top: 0;
        }
    }
}
